generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url = "file:./dev.db"
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String
  products Product[]
}

model Product {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  price       Float
  createdAt   DateTime  @default(now())
  categoryId  Int       @default(1)   // temporal para que Prisma no se queje
  category    Category  @relation(fields: [categoryId], references: [id])
}